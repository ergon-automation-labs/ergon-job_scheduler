# Environment variables for local development and testing
# Copy this file to .env and customize for your local environment
# Never commit .env - it's gitignored

# Database Configuration (required for tests)
# Points to postgres-vector on Kubernetes NodePort
DATABASE_HOST=localhost
DATABASE_PORT=30003
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=bot_army_job_dev

# NATS Configuration (optional, used by some tests)
NATS_HOST=localhost
NATS_PORT=4222

# Elixir Environment
MIX_ENV=dev
